OAUTH2_AUTHORIZATIONCODE_CLIENT_ID=
OAUTH2_AUTHORIZATIONCODE_CLIENT_SECRET=
OAUTH2_AUTHORIZATIONCODE_REDIRECT_URI=
OAUTH2_AUTHORIZATIONCODE_AUTH_URL=https://identity.apaleo.com/connect/authorize
OAUTH2_AUTHORIZATIONCODE_TOKEN_URL=https://identity.apaleo.com/connect/token
OAUTH2_AUTHORIZATIONCODE_SCOPES=openid profile offline_access availability.read rates.read reservations.read identity:account-users.read
OAUTH2_AUTHORIZATIONCODE_PKCE=false
#acess and refresh tokens get added only after login flow
OAUTH2_AUTHORIZATIONCODE_ACCESS_TOKEN=
OAUTH2_AUTHORIZATIONCODE_REFRESH_TOKEN=
